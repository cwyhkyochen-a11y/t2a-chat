    "dev": "node --watch src/index.js",
    "example:echo": "node examples/echo-bot/server.js"
  },
  "keywords": [
    "t2a",
    "chat",
    "llm",
    "agent",
    "websocket",
    "form-block",
    "interactive-form",
    "chat-ui",
    "openai",
    "claude",
    "gemini",
    "tool-calling",
    "system-event",
    "embeddable"
  ],
  "author": "kyochen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cwyhkyochen-a11y/t2a-chat.git"
  },
  "homepage": "https://github.com/cwyhkyochen-a11y/t2a-chat#readme",
  "bugs": {
    "url": "https://github.com/cwyhkyochen-a11y/t2a-chat/issues"
  },
  "dependencies": {
    "@t2a/core": "^0.6.2",
    "better-sqlite3": "^11.0.0",
    "ws": "^8.16.0"
  },
  "engines": {
