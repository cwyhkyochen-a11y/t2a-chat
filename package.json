{
  "name": "@t2a/chat",
  "version": "0.7.0",
  "description": "Talk-to-Action Chat Runtime — the official UI/runtime layer for @t2a/core. Embeddable WebSocket chat with native interactive forms, slot system, tool rendering, and multi-modal attachments.",
  "main": "src/index.js",
  "files": [
    "src",
    "public",
    "scripts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
